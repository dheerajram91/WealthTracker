@{
    ViewData["Title"] = "Privacy Policy & Disclosures";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">
            <div class="card border-0 shadow-sm p-4 p-md-5 bg-white rounded-3">
                <div class="text-center mb-5">
                    <div class="d-inline-block bg-light text-primary rounded-circle p-3 mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" fill="currentColor" class="bi bi-shield-lock" viewBox="0 0 16 16">
                          <path d="M8 1a2 2 0 0 1 2 2v2H6V3a2 2 0 0 1 2-2zm3 4V3a3 3 0 0 0-6 0v2H5a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2zM5 8h6v6H5V8zm1 1v4h4V9H6z"/>
                        </svg>
                    </div>
                    <h1 class="display-5 fw-bold text-dark mb-2">Privacy & Transparency</h1>
                    <p class="lead text-muted">Your financial inputs, configurations, and portfolios belong entirely to you.</p>
                </div>

                <hr class="my-4 text-muted opacity-25">

                <div class="row g-4">
                    <div class="col-12">
                        <div class="d-flex align-items-start gap-3">
                            <div class="bg-success-subtle text-success rounded-3 p-2 mt-1">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-database-x" viewBox="0 0 16 16">
                                  <path d="M12.096 6.223A4.92 4.92 0 0 0 13 5.698V7c0 .289-.213.654-.753 1.007-.529.345-1.285.64-2.247.64s-1.718-.295-2.247-.64C7.213 7.654 7 7.29 7 7V5.698c.311.23.67.432 1.07.593.633.255 1.411.409 2.23.409.819 0 1.597-.154 2.23-.41z"/>
                                  <path d="M12.096 2.223A4.92 4.92 0 0 0 13 1.698V3c0 .289-.213.654-.753 1.007-.529.345-1.285.64-2.247.64s-1.718-.295-2.247-.64C7.213 3.654 7 3.29 7 3V1.698c.311.23.67.432 1.07.593.633.255 1.411.409 2.23.409.819 0 1.597-.154 2.23-.41z"/>
                                  <path d="M9 11.5c0-.623.113-1.22.32-1.777C8.285 9.64 7.529 9.344 7 9c-.54-.353-.753-.718-.753-1.007V9.3c0 .289.213.654.753 1.007.411.268.96.486 1.62.593.22.256.484.479.78.658A4.952 4.952 0 0 1 9 11.5z"/>
                                  <path d="M8 4.7c.633.256 1.411.41 2.23.41.819 0 1.597-.154 2.23-.41.4-.162.759-.364 1.07-.593V1.5c0-.896-.807-1.5-2.5-1.5S8.5.604 8.5 1.5c0 .896.807 1.5 2.5 1.5.819 0 1.597-.154 2.23-.41V3.5c0 .896-.807 1.5-2.5 1.5S8.5 4.104 8.5 5c0 .896.807 1.5 2.5 1.5.819 0 1.597-.154 2.23-.41V5.5c0 .289-.213.654-.753 1.007-.113.074-.24.143-.377.206a5.507 5.507 0 0 0-1.782-.99V4.7z"/>
                                  <path d="M12.5 16a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7zm-.646-4.854.646.647.646-.647a.5.5 0 0 1 .708.708l-.647.646.647.646a.5.5 0 0 1-.708.708l-.646-.647-.646.647a.5.5 0 0 1-.708-.708z"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="h5 fw-bold text-dark">Zero Server Storage</h3>
                                <p class="text-muted">We do not store your assets, percentages, inputs, investment dates, or calculated results on any server database. This site is completely database-free when it comes to personal financial data.</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="d-flex align-items-start gap-3">
                            <div class="bg-primary-subtle text-primary rounded-3 p-2 mt-1">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-link-45deg" viewBox="0 0 16 16">
                                  <path d="M4.715 6.542 3.343 7.914a3 3 0 1 0 4.243 4.243l1.828-1.829A3 3 0 0 0 8.586 5.5L8 6.086a1.002 1.002 0 0 0-.154.199 2 2 0 0 1 .861 3.337L6.88 11.45a2 2 0 1 1-2.83-2.83l.793-.792a4.018 4.018 0 0 1-.128-1.287z"/>
                                  <path d="M6.586 10.5h-.001a1 1 0 0 0 .154-.199 2 2 0 0 1-.861-3.337L7.12 5.55a2 2 0 1 1 2.83 2.83l-.793.792a4.018 4.018 0 0 1 .128 1.287l1.372-1.372a3 3 0 1 0-4.243-4.243L4.715 6.542z"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="h5 fw-bold text-dark">Encoded Portfolio Sharing</h3>
                                <p class="text-muted">When you share a portfolio, the generated link does not reference a record in a database. Instead, the link is a compact, <strong>base64-encoded representation of your exact inputs</strong>. When someone opens the link, their browser decodes the URL parameter client-side, recreating the portfolio locally on the fly.</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="d-flex align-items-start gap-3">
                            <div class="bg-info-subtle text-info rounded-3 p-2 mt-1">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-compass" viewBox="0 0 16 16">
                                  <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm.5-7.5a.5.5 0 1 1-1 0 .5.5 0 0 1 1 0z"/>
                                  <path d="M8 4a.5.5 0 0 1 .5.5v.793a.5.5 0 0 1-1 0V4.5A.5.5 0 0 1 8 4zM8 11a.5.5 0 0 1 .5.5v.793a.5.5 0 0 1-1 0V11.5a.5.5 0 0 1 .5-.5zm3.5-3.5a.5.5 0 0 1 .5.5v.793a.5.5 0 0 1-1 0V8a.5.5 0 0 1 .5-.5zM4 8a.5.5 0 0 1 .5-.5h.793a.5.5 0 0 1 0 1H4.5A.5.5 0 0 1 4 8z"/>
                                  <path d="m8.93 6.588-2.29.287-.08.08L6.287 9.25a.5.5 0 0 0 .708.708l2.29-.287.08-.08 2.274-2.273a.5.5 0 0 0-.708-.708z"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="h5 fw-bold text-dark">Mission & Educational Intent</h3>
                                <p class="text-muted">WealthTracker is created with the sole intent of fostering <strong>investment awareness and enabling side-by-side comparison of different asset classes and markets</strong>. We believe that seeing transparent, data-driven comparisons of historical index growths empowers users to make more informed long-term financial decisions.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="alert alert-warning border-0 rounded-3 p-4 mt-5 mb-0 d-flex gap-3 align-items-center">
                    <div class="text-warning">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="bi bi-exclamation-triangle" viewBox="0 0 16 16">
                          <path d="M7.938 2.016A.13.13 0 0 1 8.002 2a.13.13 0 0 1 .063.016.146.146 0 0 1 .054.057l6.857 11.667c.036.06.035.124.002.183a.163.163 0 0 1-.054.06.116.116 0 0 1-.066.017H1.147a.115.115 0 0 1-.066-.017.163.163 0 0 1-.054-.06.176.176 0 0 1 .002-.183L7.884 2.073a.147.147 0 0 1 .054-.057zm1.044-.45a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566z"/>
                          <path d="M7.002 12a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 5.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995z"/>
                        </svg>
                    </div>
                    <div>
                        <h4 class="h6 fw-bold text-dark mb-1">Disclaimer & Disclosure</h4>
                        <p class="small text-muted mb-0">All historical information and calculations rendered on this site are for educational purposes only. Past performance is not indicative of future market returns. WealthTracker does not offer financial advice, portfolio management, or trade execution services.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
