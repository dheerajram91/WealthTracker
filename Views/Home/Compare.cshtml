@using WealthTracker.Helper
@{
    ViewData["Title"] = "Compare Strategies";
    var allowedSymbols = DataProcessHelper.AllowedSymbols;
    var symbolDescriptions = DataProcessHelper.SymbolDescriptions;
}

<div class="container mt-4">
    <h2>Compare Strategies</h2>
    <hr />

    <div id="strategiesContainer"></div>

    <div id="formError" class="alert alert-danger" role="alert" style="display:none;"></div>

    <div class="mt-3">
        <button type="button" class="btn btn-secondary" onclick="addStrategy()">+ Add Strategy</button>
        <button type="button" class="btn btn-primary" onclick="submitCompare()">Compare</button>
    </div>

    <div id="resultsArea" class="mt-5" style="display:none;">
        <h3 class="h4 mb-3">Comparison Results</h3>
        <div id="coefficients" class="mb-4"></div>
 
        <div class="card mb-4">
            <div class="card-body p-2 p-md-3">
                <div class="chart-container">
                    <canvas id="compareChart"></canvas>
                </div>
            </div>
        </div>
 
        <p class="text-muted"><strong>Period:</strong> <span id="periodRange" class="text-white"></span></p>

        <!-- Custom Start Date dropdown and Toggle slider side by side -->
        <div class="mb-3 d-flex flex-wrap align-items-center gap-4">
            <!-- Start Date dropdown -->
            <div class="d-flex align-items-center">
                <label for="customStartDateSelect" class="me-2 fw-bold">Filter Start Date:</label>
                <select id="customStartDateSelect" class="form-select d-inline-block w-auto" onchange="onStartDateChange(this.value)">
                    <option value="">Default (Oldest Available)</option>
                </select>
            </div>

            <!-- Toggle slider between SIP and NO SIP -->
            <div class="d-flex align-items-center">
                <span id="noSipLabel" class="me-2">NO SIP</span>

                <div class="form-check form-switch mx-2">
                    <input class="form-check-input" type="checkbox" id="sipToggle" checked onchange="onSIPToggle(this.checked)" role="switch" aria-checked="true" aria-label="Toggle SIP mode">
                </div>

                <span id="sipLabel" class="ms-2 fw-bold">SIP</span>
            </div>
        </div>
    </div>
</div>

<template id="strategyTemplate">
    <div class="card mb-3 strategy-entry">
        <div class="card-header d-flex justify-content-between">
            <h5 class="mb-0">Strategy</h5>
            <button class="btn btn-sm btn-danger" onclick="removeStrategy(this)">Remove Strategy</button>
        </div>
        <div class="card-body">
            <h6>Assets</h6>
            <div class="items-container"></div>
            <button type="button" class="btn btn-sm btn-outline-info mt-2" onclick="addItem(this)">+ Add Asset</button>
        </div>
    </div>
</template>

<template id="itemTemplate">
    <div class="row mb-2 item-row">
        <div class="col-md-6">
            <select class="form-control symbol-select">
                @foreach (var sym in allowedSymbols)
                {
                    var desc = symbolDescriptions.ContainsKey(sym) ? symbolDescriptions[sym] : string.Empty;
                    <option value="@sym" data-desc="@desc">@sym@if(!string.IsNullOrEmpty(desc)){<text> - @desc</text>}</option>
                }
            </select>
        </div>
        <div class="col-md-4">
            <input type="number" class="form-control percentage-input" placeholder="Percentage (%)" min="0" max="100">
        </div>
        <div class="col-md-2">
            <button class="btn btn-outline-danger" onclick="this.closest('.item-row').remove()">×</button>
        </div>
    </div>
</template>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let chartInstance = null;
        let latestResults = null; // stored server response results array
        let originalServerData = null; // stored original full response payload
        let currentMode = 'SIP'; // 'SIP' or 'NO_SIP'

        function getRescaledResults(results, k) {
            return results.map((r, i) => {
                const sipPoints = r.graphData || r.GraphData || [];
                const noSipPoints = r.graphDataNoSIP || r.GraphDataNoSIP || [];
                
                if (k < 0 || k >= sipPoints.length) return r;

                const W_sip_k = sipPoints[k].wealth ?? sipPoints[k].Wealth;
                const W_nosip_k = noSipPoints[k].wealth ?? noSipPoints[k].Wealth;

                const A_k = W_nosip_k / 100;
                const B_k = (W_sip_k - W_nosip_k) / 5;

                const rescaledSip = [];
                const rescaledNoSip = [];

                for (let j = k; j < sipPoints.length; j++) {
                    const W_sip_j = sipPoints[j].wealth ?? sipPoints[j].Wealth;
                    const W_nosip_j = noSipPoints[j].wealth ?? noSipPoints[j].Wealth;

                    const A_j = W_nosip_j / 100;
                    const B_j = (W_sip_j - W_nosip_j) / 5;

                    const A_prime_j = A_k > 0 ? (A_j / A_k) : 0;
                    const B_prime_j = B_j - A_prime_j * B_k;

                    rescaledSip.push({
                        month: sipPoints[j].month || sipPoints[j].Month,
                        wealth: Math.round((100 * A_prime_j + 5 * B_prime_j) * 100) / 100
                    });

                    rescaledNoSip.push({
                        month: noSipPoints[j].month || noSipPoints[j].Month,
                        wealth: Math.round((100 * A_prime_j) * 100) / 100
                    });
                }

                // Final coefficients at the last point
                const final_A_prime = A_k > 0 ? ( (noSipPoints[noSipPoints.length - 1].wealth ?? noSipPoints[noSipPoints.length - 1].Wealth) / 100 / A_k ) : 0;
                const final_B_prime = ( (sipPoints[sipPoints.length - 1].wealth ?? sipPoints[sipPoints.length - 1].Wealth) - (noSipPoints[noSipPoints.length - 1].wealth ?? noSipPoints[noSipPoints.length - 1].Wealth) ) / 5 - final_A_prime * B_k;

                return {
                    id: r.id || r.Id,
                    message: r.message || r.Message,
                    coefficientA: final_A_prime,
                    coefficientB: final_B_prime,
                    graphData: rescaledSip,
                    graphDataNoSIP: rescaledNoSip
                };
            });
        }
        const palette = [
            'rgb(75, 192, 192)',
            'rgb(54, 162, 235)',
            'rgb(255, 99, 132)',
            'rgb(255, 159, 64)',
            'rgb(153, 102, 255)',
            'rgb(201, 203, 207)',
            'rgb(99, 255, 132)'
        ];

        document.addEventListener("DOMContentLoaded", () => {
            addStrategy();
            addStrategy(); // pre-add two strategies for convenience

            // initialize label styling according to toggle
            const checked = document.getElementById('sipToggle')?.checked;
            updateToggleLabels(checked);
        });

        function addStrategy() {
            const container = document.getElementById('strategiesContainer');
            const template = document.getElementById('strategyTemplate').content.cloneNode(true);
            container.appendChild(template);
            // add one default item to the new strategy
            const lastStrategy = container.lastElementChild;
            addItem(lastStrategy.querySelector('.btn-outline-info'));
            updateStrategyTitles();
        }

        function removeStrategy(button) {
            const entry = button.closest('.strategy-entry');
            if (!entry) return;
            entry.remove();
            updateStrategyTitles();
        }

        function updateStrategyTitles() {
            const entries = document.querySelectorAll('.strategy-entry');
            entries.forEach((entry, idx) => {
                const header = entry.querySelector('h5.mb-0');
                if (header) {
                    header.innerText = `Strategy-${idx + 1}`;
                }
            });
        }

        function addItem(button) {
            const container = button.previousElementSibling;
            const template = document.getElementById('itemTemplate').content.cloneNode(true);
            container.appendChild(template);
        }

        function showFormError(message) {
            const err = document.getElementById('formError');
            err.innerText = message;
            err.style.display = 'block';
            err.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        function clearFormError() {
            const err = document.getElementById('formError');
            err.innerText = '';
            err.style.display = 'none';
        }

        async function submitCompare() {
            clearFormError();

            const strategyElements = document.querySelectorAll('.strategy-entry');
            if (!strategyElements.length) {
                showFormError("Add at least one strategy to compare.");
                return;
            }

            const compareItems = [];

            for (let i = 0; i < strategyElements.length; i++) {
                const el = strategyElements[i];
                const items = {};
                let pctSum = 0;
                el.querySelectorAll('.item-row').forEach(row => {
                    const sym = row.querySelector('.symbol-select').value;
                    const pct = parseFloat(row.querySelector('.percentage-input').value) || 0;
                    items[sym] = pct;
                    pctSum += pct;
                });

                if (Object.keys(items).length === 0) {
                    showFormError(`Strategy #${i + 1} has no assets.`);
                    return;
                }

                if (Math.abs(pctSum - 100) > 0.01) {
                    showFormError(`Percentages in Strategy #${i + 1} must sum to 100%. Current sum: ${pctSum.toFixed(2)}%.`);
                    return;
                }

                compareItems.push({ Portfolio: items });
            }

            const requestBody = { CompareItems: compareItems };

            try {
                const response = await fetch('/compare', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(requestBody)
                });

                if (!response.ok) {
                    const errText = await response.text();
                    showFormError("Server error: " + errText);
                    return;
                }

                const data = await response.json();
                renderResults(data);
            } catch (err) {
                console.error("Fetch error:", err);
                showFormError("Failed to communicate with the server. Check your network connection.");
            }
        }

        // Called by the checkbox toggle. 'checked' true => SIP, false => NO_SIP
        function onSIPToggle(checked) {
            updateToggleLabels(checked);
            const mode = checked ? 'SIP' : 'NO_SIP';
            onSIPModeChange(mode);
        }

        function updateToggleLabels(checked) {
            const sipLabel = document.getElementById('sipLabel');
            const noSipLabel = document.getElementById('noSipLabel');
            if (sipLabel && noSipLabel) {
                sipLabel.classList.toggle('fw-bold', !!checked);
                noSipLabel.classList.toggle('fw-bold', !checked);
            }
        }

        function onSIPModeChange(mode) {
            currentMode = mode;
            if (latestResults) {
                const selectVal = document.getElementById('customStartDateSelect')?.value;
                if (selectVal) {
                    const firstGraph = getGraphArrayForMode(latestResults[0] || {}, 'SIP');
                    const labels = firstGraph.map(d => d.month || d.Month);
                    const k = labels.indexOf(selectVal);
                    if (k >= 0) {
                        const rescaled = getRescaledResults(latestResults, k);
                        renderChartFromResults(rescaled, currentMode);
                        return;
                    }
                }
                renderChartFromResults(latestResults, currentMode);
            }
        }

        function getGraphArrayForMode(resultItem, mode) {
            // Prefer the selected mode's array; fall back to other available arrays if missing
            if (mode === 'NO_SIP') {
                return resultItem.graphDataNoSIP || resultItem.GraphDataNoSIP || resultItem.graphData || resultItem.GraphData || [];
            }

            // mode === 'SIP'
            return resultItem.graphData || resultItem.GraphData || resultItem.graphDataNoSIP || resultItem.GraphDataNoSIP || [];
        }

        // Convert 'rgb(r, g, b)' or '#rrggbb' to 'rgba(r, g, b, a)'. Fallback to provided color when unknown.
        function colorToRgba(color, alpha) {
            try {
                if (!color) return `rgba(75, 192, 192, ${alpha})`;
                color = color.trim();
                if (color.startsWith('rgba')) return color; // assume caller passed correct rgba
                if (color.startsWith('rgb(')) {
                    return color.replace('rgb(', 'rgba(').replace(')', `, ${alpha})`);
                }
                if (color.startsWith('#')) {
                    const hex = color.slice(1);
                    const r = parseInt(hex.length === 3 ? hex[0] + hex[0] : hex.slice(0, 2), 16);
                    const g = parseInt(hex.length === 3 ? hex[1] + hex[1] : hex.slice(2, 4), 16);
                    const b = parseInt(hex.length === 3 ? hex[2] + hex[2] : hex.slice(4, 6), 16);
                    return `rgba(${r}, ${g}, ${b}, ${alpha})`;
                }
                // fallback: try to extract numbers
                const nums = color.match(/\d+/g);
                if (nums && nums.length >= 3) {
                    return `rgba(${nums[0]}, ${nums[1]}, ${nums[2]}, ${alpha})`;
                }
            } catch (e) {
                // ignore and fallback
            }
            return `rgba(75, 192, 192, ${alpha})`;
        }

        function renderChartFromResults(results, mode) {
            const firstGraph = getGraphArrayForMode(results[0] || {}, mode);
            const labels = firstGraph.map(d => d.month || d.Month);

            const datasets = results.map((r, i) => {
                const id = r.id || r.Id || `Strategy-${i + 1}`;
                const graph = getGraphArrayForMode(r, mode);
                const dataPoints = graph.map(p => p.wealth ?? p.Wealth);
                const color = palette[i % palette.length];
                const bg = colorToRgba(color, 0.2); // shade below the line similar to Index.cshtml
                return {
                    label: id,
                    data: dataPoints,
                    borderColor: color,
                    backgroundColor: bg,
                    tension: 0.1,
                    fill: true,
                    pointRadius: 2
                };
            });

            // Render or update chart
            if (chartInstance) {
                chartInstance.destroy();
            }

            const ctx = document.getElementById('compareChart').getContext('2d');
            chartInstance = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: datasets
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: { 
                            beginAtZero: false, 
                            title: { display: true, text: 'Wealth Units', color: '#9ca3af' },
                            grid: { color: 'rgba(255, 255, 255, 0.05)' },
                            ticks: { color: '#9ca3af' }
                        },
                        x: { 
                            title: { display: true, text: 'Time', color: '#9ca3af' },
                            grid: { color: 'rgba(255, 255, 255, 0.05)' },
                            ticks: { color: '#9ca3af' }
                        }
                    },
                    interaction: { mode: 'index', intersect: false },
                    plugins: { 
                        legend: { 
                            position: 'bottom',
                            labels: { color: '#ffffff' }
                        } 
                    }
                }
            });

            // Listen to resize to auto-recalculate height when phone rotates
            window.removeEventListener('resize', resizeChart);
            window.addEventListener('resize', resizeChart);
        }

        function resizeChart() {
            if (chartInstance) {
                chartInstance.resize();
            }
        }

        // format Date -> dd-MMM-yyyy (e.g. 01-Feb-2026)
        function formatDateDdMmmYyyy(d) {
            const dt = new Date(d);
            if (isNaN(dt)) return '';
            const day = String(dt.getDate()).padStart(2, '0');
            const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
            const mon = months[dt.getMonth()] || '';
            const year = dt.getFullYear();
            return `${day}-${mon}-${year}`;
        }

        function renderResults(data) {
            document.getElementById('resultsArea').style.display = 'block';
            originalServerData = data; // store the raw data payload for resetting/filtering
            
            const start = new Date(data.startDate || data.StartDate);
            const end = new Date(data.endDate || data.EndDate);
            document.getElementById('periodRange').innerText = `${formatDateDdMmmYyyy(start)} — ${formatDateDdMmmYyyy(end)}`;

            if (Array.isArray(data.results || data.Results)) {
                const results = data.results || data.Results;
                latestResults = results; // store for switching mode/start date without refetch

                // Populate custom start date dropdown
                const firstGraph = getGraphArrayForMode(results[0] || {}, 'SIP');
                const labels = firstGraph.map(d => d.month || d.Month);
                const select = document.getElementById('customStartDateSelect');
                select.innerHTML = '<option value="">Default (Oldest Available)</option>';
                labels.forEach((label, idx) => {
                    if (idx < labels.length - 1) { // Skip the last month because simulation requires at least 2 points
                        const opt = document.createElement('option');
                        opt.value = label;
                        opt.innerText = label;
                        select.appendChild(opt);
                    }
                });

                // Build formulas table and render chart
                renderFormulaTable(results);

                currentMode = document.getElementById('sipToggle')?.checked ? 'SIP' : 'NO_SIP';
                updateToggleLabels(document.getElementById('sipToggle')?.checked);
                renderChartFromResults(results, currentMode);

                document.getElementById('resultsArea').scrollIntoView({ behavior: 'smooth' });
            } else {
                showFormError("Unexpected response format from server.");
            }
        }

        function renderFormulaTable(results) {
            const coeffContainer = document.getElementById('coefficients');
            coeffContainer.innerHTML = '<h4>Investment Formulas</h4><h5>Where X is the lump‑sum invested at the beginning, and Y is the monthly investment (SIP)</h5>';

            const table = document.createElement('table');
            table.className = 'table table-sm';
            const thead = document.createElement('thead');
            thead.innerHTML = '<tr><th>Strategy</th><th>Investment Formula</th></tr>';
            table.appendChild(thead);
            const tbody = document.createElement('tbody');

            for (let i = 0; i < results.length; i++) {
                const r = results[i];
                const id = r.id || r.Id || `Strategy-${i + 1}`;
                const a = (r.coefficientA ?? r.CoefficientA);
                const b = (r.coefficientB ?? r.CoefficientB);

                const aVal = Number(a);
                const bVal = Number(b);
                let formula = '';
                if (Number.isFinite(aVal)) {
                    formula += `${aVal.toFixed(2)}X`;
                }
                if (Number.isFinite(bVal)) {
                    if (formula) {
                        formula += (bVal >= 0 ? ` + ${Math.abs(bVal).toFixed(2)}Y` : ` - ${Math.abs(bVal).toFixed(2)}Y`);
                    } else {
                        formula += (bVal >= 0 ? `${bVal.toFixed(2)}Y` : `-${Math.abs(bVal).toFixed(2)}Y`);
                    }
                }

                const tr = document.createElement('tr');
                tr.innerHTML = `<td>${id}</td><td>${formula}</td>`;
                tbody.appendChild(tr);
            }

            table.appendChild(tbody);
            coeffContainer.appendChild(table);
        }

        function onStartDateChange(value) {
            if (!latestResults || !originalServerData) return;

            const mode = document.getElementById('sipToggle')?.checked ? 'SIP' : 'NO_SIP';

            if (!value) {
                // Restore original results
                const start = new Date(originalServerData.startDate || originalServerData.StartDate);
                const end = new Date(originalServerData.endDate || originalServerData.EndDate);
                document.getElementById('periodRange').innerText = `${formatDateDdMmmYyyy(start)} — ${formatDateDdMmmYyyy(end)}`;

                renderFormulaTable(latestResults);
                renderChartFromResults(latestResults, mode);
                return;
            }

            // Find index of start date
            const firstGraph = getGraphArrayForMode(latestResults[0] || {}, 'SIP');
            const labels = firstGraph.map(d => d.month || d.Month);
            const k = labels.indexOf(value);
            if (k < 0) return;

            // Generate rescaled results
            const rescaled = getRescaledResults(latestResults, k);

            // Update displayed range text (display label format)
            const startLabel = labels[k];
            const displayStart = "01-" + startLabel.replace(" ", "-");
            const end = new Date(originalServerData.endDate || originalServerData.EndDate);
            document.getElementById('periodRange').innerText = `${displayStart} — ${formatDateDdMmmYyyy(end)}`;

            // Render updated table and chart
            renderFormulaTable(rescaled);
            renderChartFromResults(rescaled, mode);
        }
    </script>
}
